# ---------------------------------------------------------------------------
# Supabase — Project Settings → API
# ---------------------------------------------------------------------------
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "publishable" / anon key (safe to expose to the browser; RLS protects data).
# In newer Supabase dashboards this is labelled "Publishable key"; older ones "anon public".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Adzuna — https://developer.adzuna.com  (free tier, register an app)
# ---------------------------------------------------------------------------
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---------------------------------------------------------------------------
# Cron — protects the scheduled ingestion route. Generate any long random string:
#   node -e "console.log(crypto.randomUUID())"
# Vercel Cron must send it as the Authorization header (see README).
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# Optional: app base URL used to build magic-link / OAuth redirect URLs.
# Locally this defaults to http://localhost:3000; on Vercel set it to your domain.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# ATS public job-board tokens are NOT secrets — they live per-source in the
# `sources` table (configured in the app UI), not in env. Nothing to add here.
# ---------------------------------------------------------------------------
